[Desktop Entry]
Version=1.0
Type=Application
Name=Azan Kiosk
Comment=Launch the Azan dashboard in fullscreen kiosk mode
Icon=applications-multimedia
Terminal=false
Categories=Utility;
Exec=bash -c 'rm -f "$HOME/.config/azan-kiosk-profile/Singleton"*; rm -rf "$HOME/.config/azan-kiosk-profile/Default/Cache" "$HOME/.config/azan-kiosk-profile/Default/Code Cache" "$HOME/.config/azan-kiosk-profile/Default/GPUCache" "$HOME/.config/azan-kiosk-profile/Default/Service Worker" 2>/dev/null; BROWSER=$(command -v google-chrome || command -v chromium || command -v chromium-browser); exec "$BROWSER" --kiosk --remote-debugging-port=9222 --remote-allow-origins=* --start-fullscreen --user-data-dir="$HOME/.config/azan-kiosk-profile" --autoplay-policy=no-user-gesture-required --noerrdialogs --disable-infobars --disable-session-crashed-bubble --disable-features=TranslateUI --disable-pinch --overscroll-history-navigation=0 --no-first-run --no-default-browser-check --password-store=basic --check-for-update-interval=31536000 --disable-component-update --enable-features=VaapiVideoDecodeLinuxGL,VaapiVideoEncoder --ignore-gpu-blocklist --enable-zero-copy "http://192.168.1.146:3002"'
